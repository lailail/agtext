# Backend
BACKEND_PORT=8080

# MySQL (for docker-compose and backend)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=agtext
MYSQL_USERNAME=root
MYSQL_PASSWORD=123456

# JDBC url example (backend default composes it from the vars above)
# DB_URL=jdbc:mysql://localhost:3306/agtext?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC

# Frontend
FRONTEND_PORT=5173

# Storage (reserved for Phase 3/4)
FILE_STORAGE_ROOT=./data

# Model (Phase 2)
# Default provider name: openai / qwen / zhipu / ernie / hunyuan
MODEL_DEFAULT_PROVIDER=openai
MODEL_FALLBACK_NAME=gpt-5.1

# OpenAI
OPENAI_BASE_URL=https://api.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Alibaba Qwen (OpenAI-compatible)
QWEN_BASE_URL=
QWEN_API_KEY=
QWEN_MODEL=
QWEN_EMBEDDING_MODEL=

# Zhipu GLM (OpenAI-compatible)
ZHIPU_BASE_URL=
ZHIPU_API_KEY=
ZHIPU_MODEL=
ZHIPU_EMBEDDING_MODEL=

# Baidu ERNIE (OpenAI-compatible)
ERNIE_BASE_URL=
ERNIE_API_KEY=
ERNIE_MODEL=
ERNIE_EMBEDDING_MODEL=

# Tencent Hunyuan (OpenAI-compatible)
HUNYUAN_BASE_URL=
HUNYUAN_API_KEY=
HUNYUAN_MODEL=
HUNYUAN_EMBEDDING_MODEL=
